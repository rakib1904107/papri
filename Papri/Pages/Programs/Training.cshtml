@page "/programs/training"
@model Papri.Pages.Programs.TrainingModel
@{
    ViewData["Title"] = "Training";
}

<section class="container-fluid px-3 px-lg-3 py-4">
    <div class="mb-5 pb-2 text-center">
        <h1 class="h3 mb-1 text-uppercase">Training</h1>
        <p class="text-muted mb-0">PAPRI's training cell at a glance.</p>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 p-md-4">
            <p class="mb-0">
                Training changes knowledge, level of skills and attitude of human beings on a
                specific subject. It builds up the capacity of participants. Training also helps
                implement any activity more efficiently and effectively. PAPRI has developed a
                training cell to organize and conduct internal training programs for its staff
                and beneficiaries. It also provides training for personnel from other
                organizations and individuals.
            </p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 p-md-4">
            <h2 class="h5 text-primary mb-4">PAPRI's Training Cell at a Glance</h2>

            <div class="training-section mb-4">
                <h3 class="h6 fw-bold mb-1">01. Training Coordinator: 01</h3>
                <p class="text-muted mb-0">Full-time engaged in training-related work.</p>
            </div>

            <div class="training-section mb-4">
                <h3 class="h6 fw-bold mb-1">02. Trainers: 16</h3>
                <p class="text-muted mb-0">
                    Human and technical skill-development trainers — they also develop the
                    module, schedule and curriculum of required training.
                </p>
            </div>

            <div class="training-section mb-4">
                <h3 class="h6 fw-bold mb-3">03. Training Venues: 03</h3>

                <div class="training-venue mb-4">
                    <h4 class="h6 fw-semibold mb-2">1. PAPRI Narayanpur Training Centre (Residential)</h4>
                    <ul class="mb-0">
                        <li>32-seat training room with sophisticated chairs</li>
                        <li>35-capacity dormitory</li>
                        <li>Dining hall</li>
                        <li>Computer and laptop facility</li>
                        <li>Multimedia projector</li>
                        <li>Library</li>
                        <li>Separate dining room</li>
                        <li>Well-facilitated toilet &amp; bath</li>
                        <li>Electricity available (Govt. electricity and own generator)</li>
                        <li>Campus has its own protected boundary</li>
                        <li>Security guard</li>
                        <li>Situated beside Dhaka–Sylhet highway</li>
                        <li>Local market nearby</li>
                    </ul>
                </div>

                <div class="training-venue mb-4">
                    <h4 class="h6 fw-semibold mb-2">2. PAPRI Amlabo Training Centre (Residential)</h4>
                    <ul class="mb-0">
                        <li>Training room with 32-seat capacity</li>
                        <li>33-capacity dormitory</li>
                        <li>Dining hall</li>
                        <li>Computer and laptop facility</li>
                        <li>Multimedia projector</li>
                        <li>Separate dining room</li>
                        <li>Well-facilitated toilet &amp; bath</li>
                        <li>Electricity available (Govt. electricity and own generator)</li>
                        <li>Campus has its own protected boundary</li>
                        <li>Security guard</li>
                        <li>Carpeted road beside the centre</li>
                        <li>Local market nearby</li>
                    </ul>
                </div>

                <div class="training-venue mb-4">
                    <h4 class="h6 fw-semibold mb-2">3. Narsingdi Training Centre (Non-residential)</h4>
                    <p class="text-muted small mb-2">Situated at the heart of the District town.</p>
                    <ul class="mb-0">
                        <li>30-seat training room with sophisticated chairs</li>
                        <li>Computer and laptop facility</li>
                        <li>Multimedia projector</li>
                        <li>Separate dining room</li>
                        <li>Well-facilitated toilet &amp; bath</li>
                        <li>Electricity available (Govt. electricity and own generator)</li>
                        <li>3rd floor of a six-storey building</li>
                        <li>Security guard</li>
                    </ul>
                </div>

                <div class="training-venue mb-0">
                    <h4 class="h6 fw-semibold mb-2">4. Computer Training Centre</h4>
                    <ul class="mb-0">
                        <li>Training house (semi-pacca)</li>
                        <li>8-seat capacity</li>
                        <li>8 computers and 4 laptops with computer chairs</li>
                        <li>33-capacity dormitory</li>
                        <li>Professional computer instructor</li>
                    </ul>
                </div>
            </div>

            <h2 class="h5 text-primary mb-4">Other Facilities</h2>
            <div class="row g-3">
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-projector text-primary me-2 fs-5"></i>
                        <span class="fw-medium">05. Multimedia projector</span>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-camera text-primary me-2 fs-5"></i>
                        <span class="fw-medium">06. Digital camera</span>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-file-earmark-text text-primary me-2 fs-5"></i>
                        <span class="fw-medium">07. Documentation facilities</span>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-book text-primary me-2 fs-5"></i>
                        <span class="fw-medium">08. Well-designed library</span>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-wifi text-primary me-2 fs-5"></i>
                        <span class="fw-medium">09. Internet facilities</span>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-journal-text text-primary me-2 fs-5"></i>
                        <span class="fw-medium">10. Reading room</span>
                    </div>
                </div>
            </div>

            <p class="text-muted small mt-4 mb-0">
                All other necessary materials and facilities are available in the training venues.
            </p>
        </div>
    </div>
</section>
