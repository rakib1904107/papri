@page "/career"
@model Papri.Pages.CareerModel
@{
    ViewData["Title"] = "Career";
}

<section class="container-fluid px-3 px-lg-3 py-4">
    <div class="mb-5 pb-2 text-center">
        <h1 class="h3 mb-1 text-uppercase">Career Opportunities at PAPRI</h1>
        <p class="text-muted mb-0">Open positions and recent job circulars. Click any circular to view the full PDF.</p>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 p-md-4">
            <h2 class="h5 text-primary mb-3"><i class="bi bi-briefcase me-2"></i>Open Positions</h2>
            @if (Model.OpenJobs.Count == 0)
            {
                <p class="text-muted mb-0">There are no open positions at the moment. Please check back later.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" style="width: 4rem;">SL</th>
                                <th scope="col">Job Title</th>
                                <th scope="col" style="width: 10rem;">Posted</th>
                                <th scope="col" style="width: 10rem;">Deadline</th>
                                <th scope="col" style="width: 9rem;" class="text-end">Circular</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.OpenJobs.Count; i++)
                            {
                                var j = Model.OpenJobs[i];
                                <tr>
                                    <td class="fw-semibold text-muted">@(i + 1)</td>
                                    <td class="fw-medium">
                                        <a href="@j.CircularPath" target="_blank" rel="noopener" class="text-decoration-none">@j.JobTitle</a>
                                    </td>
                                    <td>@j.PostedDate.ToString("dd MMM yyyy")</td>
                                    <td>@j.Deadline.ToString("dd MMM yyyy")</td>
                                    <td class="text-end">
                                        <a href="@j.CircularPath" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-file-earmark-pdf me-1"></i>View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

</section>
