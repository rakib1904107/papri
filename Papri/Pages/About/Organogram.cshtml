@page "/about/organogram"
@model Papri.Pages.About.OrganogramModel
@{
    ViewData["Title"] = "Organogram";
}

<section class="container-fluid px-3 px-lg-5 py-4">
    <div class="mb-5 pb-2 text-center">
        <h1 class="h3 mb-1 text-uppercase">Organogram</h1>
        <p class="text-muted mb-0">PAPRI organisational structure.</p>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3 p-md-4 text-center">
            <img src="~/images/organogram.jpeg"
                 alt="PAPRI Organogram"
                 class="img-fluid organogram-img"
                 onerror="this.style.display='none'; document.getElementById('organogramFallback').style.display='block';" />
            <div id="organogramFallback" class="text-muted py-5" style="display:none;">
                <i class="bi bi-diagram-3 display-4 d-block mb-2"></i>
                Organogram image not available.
            </div>
        </div>
    </div>
</section>
