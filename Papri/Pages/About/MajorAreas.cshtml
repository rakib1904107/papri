@page "/about/major-areas"
@model Papri.Pages.About.MajorAreasModel
@{
    ViewData["Title"] = "Major Areas";
    var areas = new (string Icon, string Name)[] {
        ("bi-book",            "Basic Literacy"),
        ("bi-mortarboard",     "Education"),
        ("bi-universal-access","Handicapped development"),
        ("bi-briefcase",       "Livelihood program"),
        ("bi-people",          "Adolescent development"),
        ("bi-heart",           "Women & child rights"),
        ("bi-gender-ambiguous","Gender development"),
        ("bi-easel",           "Training and capacity building"),
        ("bi-shield-exclamation","Disaster management")
    };
}

<section class="container-fluid px-3 px-lg-5 py-4">
    <div class="mb-5 pb-2 text-center">
        <h1 class="h3 mb-1 text-uppercase">Major Areas</h1>
        <p class="text-muted mb-0">Major areas where PAPRI works.</p>
    </div>

    <div class="row g-3">
        @foreach (var a in areas)
        {
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm major-area-card">
                    <div class="card-body d-flex align-items-center">
                        <div class="major-area-icon me-3">
                            <i class="bi @a.Icon"></i>
                        </div>
                        <span class="fw-semibold">@a.Name</span>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
