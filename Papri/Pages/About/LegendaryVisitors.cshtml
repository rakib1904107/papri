@page "/about/legendary-visitors"
@model Papri.Pages.About.LegendaryVisitorsModel
@{
    ViewData["Title"] = "Legendary Visitors";
}

<section class="container-fluid px-3 px-lg-3 py-4">
    <div class="mb-5 pb-2 text-center">
        <h1 class="h3 mb-1 text-uppercase">Legendary Visitors</h1>
        <p class="text-muted mb-0">Dignitaries who have visited PAPRI from home and abroad.</p>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 p-md-4">
            <p class="mb-0">
                A lot of dignitaries have visited PAPRI from home and abroad. They include
                government high officials, UN agencies, European Union representatives,
                university teachers and researchers, development activists and many more.
                A small portion of these visitors is listed below.
            </p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3 p-md-4">
            @if (Model.Items.Count == 0)
            {
                <p class="text-muted text-center mb-0 py-4">No legendary visitors recorded yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" style="width: 4rem;">SL</th>
                                <th scope="col" style="min-width: 14rem;">Name</th>
                                <th scope="col" style="min-width: 12rem;">Designation</th>
                                <th scope="col" style="min-width: 16rem;">Country / Institution</th>
                                <th scope="col" style="min-width: 8rem;">Year</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Items.Count; i++)
                            {
                                var v = Model.Items[i];
                                <tr>
                                    <td class="fw-semibold text-muted">@(i + 1)</td>
                                    <td class="fw-medium">@v.Name</td>
                                    <td>@(string.IsNullOrWhiteSpace(v.Designation) ? "—" : v.Designation)</td>
                                    <td>@(string.IsNullOrWhiteSpace(v.CountryInstitution) ? "—" : v.CountryInstitution)</td>
                                    <td>@(string.IsNullOrWhiteSpace(v.Year) ? "—" : v.Year)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>
