@page "/about/donors-partners"
@model Papri.Pages.About.DonorsPartnersModel
@{
    ViewData["Title"] = "Donors/Partners";
}

<section class="container-fluid px-3 px-lg-3 py-4">
    <div class="mb-5 pb-2 text-center">
        <h1 class="h3 mb-1 text-uppercase">Donors / Partners of PAPRI</h1>
        <p class="text-muted mb-0">Collaboration, partnership and networking for the well-being of our target people.</p>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4 p-md-5">
            <p class="mb-0">
                PAPRI implements its activities with its own fund. It believes in collaboration,
                partnership and networking for the greater interest of people. It also receives
                donations and develops partnerships with UN agencies, international and national
                NGOs, and the Government of Bangladesh to implement development activities for
                the well-being of target people.
            </p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4 p-md-5">
            <h2 class="h5 text-primary mb-4">
                <i class="bi bi-broadcast me-2"></i>Ongoing Donors / Partners
            </h2>
            @if (Model.Ongoing.Count == 0)
            {
                <p class="text-muted mb-0">No ongoing donors / partners listed.</p>
            }
            else
            {
                <ul class="list-group list-group-flush target-list">
                    @foreach (var item in Model.Ongoing)
                    {
                        <li class="list-group-item d-flex align-items-center">
                            <i class="bi bi-check2-circle text-success me-3 fs-5"></i>
                            <span class="fw-medium">@item.Name</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4 p-md-5">
            <h2 class="h5 text-primary mb-4">
                <i class="bi bi-clock-history me-2"></i>Previous Donors / Partners
            </h2>
            @if (Model.Previous.Count == 0)
            {
                <p class="text-muted mb-0">No previous donors / partners listed.</p>
            }
            else
            {
                <ul class="list-group list-group-flush target-list">
                    @foreach (var item in Model.Previous)
                    {
                        <li class="list-group-item d-flex align-items-center">
                            <i class="bi bi-archive text-secondary me-3 fs-5"></i>
                            <span class="fw-medium">@item.Name</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5">
            <h2 class="h5 text-primary mb-4">
                <i class="bi bi-diagram-3 me-2"></i>Networks PAPRI is a Member Of
            </h2>
            @if (Model.Networks.Count == 0)
            {
                <p class="text-muted mb-0">No network memberships listed.</p>
            }
            else
            {
                <ul class="list-group list-group-flush target-list">
                    @foreach (var item in Model.Networks)
                    {
                        <li class="list-group-item d-flex align-items-center">
                            <i class="bi bi-people-fill text-primary me-3 fs-5"></i>
                            <span class="fw-medium">@item.Name</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</section>
