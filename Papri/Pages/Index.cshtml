@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
    var statIcons = new[] { "bi-people-fill", "bi-geo-alt-fill", "bi-bar-chart-fill", "bi-share-fill" };
}

<div class="home-page">

    <!-- ===================== 1. HERO (full-width slider + overlay text) ===================== -->
    <section class="home-hero">
        @if (Model.Slides.Any())
        {
            <div id="homeHeroCarousel" class="carousel slide home-hero-carousel" data-bs-ride="carousel" data-bs-interval="4000">
                <div class="carousel-inner">
                    @for (var i = 0; i < Model.Slides.Count; i++)
                    {
                        var s = Model.Slides[i];
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <img src="@s.ImagePath" alt="@(s.Caption ?? "PAPRI")" class="home-hero-image" />
                        </div>
                    }
                </div>
                @if (Model.Slides.Count > 1)
                {
                    <button class="carousel-control-prev home-hero-control" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next home-hero-control" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                }
            </div>
        }
        else
        {
            <div class="home-hero-fallback"><i class="bi bi-image"></i></div>
        }

        <div class="home-hero-overlay">
            <div class="container-fluid px-3 px-lg-5">
                <div class="home-hero-card">
                    <h1 class="home-hero-title">Empowering Communities<br />for Sustainable Development</h1>
                    <p class="home-hero-sub">PAPRI works with marginalized communities across Bangladesh to reduce poverty and build sustainable livelihoods.</p>
                    <div class="home-hero-actions">
                        <a href="/about/profile" class="btn home-hero-btn-primary">Learn More <i class="bi bi-arrow-right ms-1"></i></a>
                        <a href="/programs/ongoing" class="btn home-hero-btn-secondary">Our Programs</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===================== 2. ABOUT PAPRI ===================== -->
    <section class="container-fluid px-3 px-lg-5 py-5">
        <div class="row g-4 align-items-center">
            <div class="col-lg-7">
                <h2 class="h3 fw-bold mb-3">About PAPRI</h2>
                <p class="text-muted mb-4 home-about-text">
                    PAPRI is a non-government voluntary development organization established in 1999,
                    working to empower rural communities through sustainable development programs in
                    Narsingdi and beyond.
                </p>
                <a href="/about/profile" class="btn home-hero-btn-primary">Read More <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
            <div class="col-lg-5">
                <img src="~/images/about-side.jpg" alt="About PAPRI" class="img-fluid rounded home-about-image"
                     onerror="this.style.display='none'" />
            </div>
        </div>
    </section>

    <!-- ===================== 3. STATS (white panel) ===================== -->
    @if (Model.Stats.Any())
    {
        <section class="container-fluid px-3 px-lg-5 pb-5">
            <div class="home-stats-panel">
                <div class="row g-4">
                    @for (var i = 0; i < Model.Stats.Count; i++)
                    {
                        var stat = Model.Stats[i];
                        var icon = i < statIcons.Length ? statIcons[i] : "bi-graph-up";
                        <div class="col-6 col-md-3">
                            <div class="home-stat">
                                <div class="home-stat-icon">
                                    <i class="bi @icon"></i>
                                </div>
                                <div>
                                    <div class="home-stat-value">@stat.Value</div>
                                    <div class="home-stat-label">@stat.Label</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    <!-- ===================== 4. OUR IMPACT ===================== -->
    @if (Model.ImpactPrograms.Any())
    {
        <section class="container-fluid px-3 px-lg-5 pb-5">
            <h2 class="h3 fw-bold mb-4">Our Impact</h2>
            <div class="row g-4">
                @foreach (var p in Model.ImpactPrograms)
                {
                    var preview = p.Goal ?? p.Objective ?? "";
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="card h-100 shadow-sm border-0 program-card">
                            @if (!string.IsNullOrWhiteSpace(p.ImagePath))
                            {
                                <img src="@p.ImagePath" alt="@p.Title" class="program-card-image" />
                            }
                            else
                            {
                                <div class="program-card-image-placeholder">
                                    <i class="bi bi-image"></i>
                                </div>
                            }
                            <div class="card-body d-flex flex-column text-start">
                                <h3 class="h6 mb-2 fw-bold">@p.Title</h3>
                                <p class="program-card-preview text-muted small mb-3">@preview</p>
                                <a href="/programs/@p.Id" class="btn btn-sm learn-more-btn mt-auto mx-auto">
                                    Learn more <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-4">
                <a href="/programs/ongoing" class="btn home-view-all-btn">View All Programs <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </section>
    }

    <!-- ===================== 5. ONGOING PROJECTS ===================== -->
    @if (Model.LatestProject is not null)
    {
        var proj = Model.LatestProject;
        <section class="container-fluid px-3 px-lg-5 pb-5">
            <h2 class="h3 fw-bold mb-4">Ongoing Projects</h2>
            <div class="card shadow-sm border-0 overflow-hidden home-project-card">
                <div class="row g-0 align-items-stretch">
                    <div class="col-md-4">
                        <div class="home-project-image-frame">
                            @if (!string.IsNullOrWhiteSpace(proj.ImagePath))
                            {
                                <img src="@proj.ImagePath" alt="@proj.Title" class="home-project-image" />
                            }
                            else
                            {
                                <div class="home-project-image-placeholder">
                                    <i class="bi bi-image"></i>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="card-body p-4 p-md-4 d-flex flex-column h-100 home-project-body">
                            <h3 class="h4 fw-bold mb-2">@proj.Title</h3>
                            <p class="text-muted mb-2 small"><i class="bi bi-calendar3 me-1"></i>@proj.Date.ToString("dd MMM yyyy")</p>
                            <p class="text-muted mb-0 home-project-details">@proj.Details</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="text-center mt-4">
                <a href="/projects" class="btn home-view-all-btn">View All Projects <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </section>
    }

</div>
