@page "/admin/sliders"
@model Papri.Pages.Admin.Sliders.IndexModel
@{
    ViewData["Title"] = "Sliders";
    ViewData["SearchPlaceholder"] = "Search captions...";
    ViewData["NewButtonText"] = "New Slider";
    ViewData["NewButtonHref"] = "/admin/sliders/create";
    var currentQ = HttpContext.Request.Query["q"].ToString();
    var currentPage = HttpContext.Request.Query["page"].ToString();
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success py-2"><i class="bi bi-check-circle me-1"></i> @Model.StatusMessage</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <partial name="_SearchBar" />
        @if (!Model.Items.Any())
        {
            <p class="text-center text-muted py-4">No sliders yet.</p>
        }
        else
        {
            <div class="row g-3">
                @foreach (var item in Model.Items)
                {
                    <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                        <div class="card h-100">
                            <img src="@item.ImagePath" class="card-img-top" style="aspect-ratio: 16/9; object-fit: cover;" />
                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div class="small">
                                        <div class="fw-semibold">#@item.Id · order @item.DisplayOrder</div>
                                        @if (!string.IsNullOrEmpty(item.Caption))
                                        {
                                            <div class="text-muted text-truncate" style="max-width:180px;">@item.Caption</div>
                                        }
                                    </div>
                                    @if (item.IsActive) { <span class="badge bg-success-soft text-success">On</span> } else { <span class="badge bg-secondary">Off</span> }
                                </div>
                                <div class="d-flex gap-1 mt-2">
                                    <a class="btn btn-sm btn-outline-primary flex-fill" href="/admin/sliders/edit/@item.Id"><i class="bi bi-pencil"></i></a>
                                    <form method="post" action="/admin/sliders?handler=Delete&id=@item.Id" class="flex-fill" onsubmit="return confirm('Delete this slider?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        <partial name="_Pagination" model="(Papri.Services.IPagedList)Model.Items" />
    </div>
</div>
