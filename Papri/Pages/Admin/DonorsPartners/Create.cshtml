@page "/admin/donors-partners/create"
@model Papri.Pages.Admin.DonorsPartners.CreateModel
@{
    ViewData["Title"] = "New Donor / Partner";
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
            <div class="row g-3">
                <div class="col-md-12">
                    <label asp-for="Item.Name" class="form-label"></label>
                    <input asp-for="Item.Name" class="form-control" />
                    <span asp-validation-for="Item.Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Item.Category" class="form-label"></label>
                    <select asp-for="Item.Category" asp-items="Html.GetEnumSelectList<DonorPartnerCategory>()" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="Item.DisplayOrder" class="form-label"></label>
                    <input asp-for="Item.DisplayOrder" type="number" class="form-control" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="Item.IsActive" class="form-check-input" />
                        <label asp-for="Item.IsActive" class="form-check-label">Active</label>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save</button>
                <a href="/admin/donors-partners" class="btn btn-link">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
