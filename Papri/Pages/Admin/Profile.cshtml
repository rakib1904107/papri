@page "/admin/profile"
@model Papri.Pages.Admin.ProfileModel
@{
    ViewData["Title"] = "User Profile";
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i> @Model.StatusMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i> @Model.ErrorMessage</div>
}

<div class="row g-4">
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3"><i class="bi bi-envelope me-1"></i> Update Email</h5>
                <p class="text-muted small mb-3">Current email: <strong>@Model.CurrentEmail</strong></p>
                <form method="post" action="/admin/profile?handler=UpdateEmail" novalidate>
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Email.NewEmail" class="form-label"></label>
                        <input asp-for="Email.NewEmail" class="form-control" />
                        <span asp-validation-for="Email.NewEmail" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save Email</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3"><i class="bi bi-key me-1"></i> Change Password</h5>
                <form method="post" action="/admin/profile?handler=ChangePassword" novalidate>
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Password.CurrentPassword" class="form-label"></label>
                        <input asp-for="Password.CurrentPassword" type="password" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="Password.CurrentPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password.NewPassword" class="form-label"></label>
                        <input asp-for="Password.NewPassword" type="password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Password.NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password.ConfirmPassword" class="form-label"></label>
                        <input asp-for="Password.ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Password.ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-shield-lock me-1"></i> Change Password</button>
                </form>
            </div>
        </div>
    </div>
</div>
