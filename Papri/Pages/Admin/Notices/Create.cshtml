@page "/admin/notices/create"
@model Papri.Pages.Admin.Notices.CreateModel
@{
    ViewData["Title"] = "New Notice";
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Item.Date" class="form-label"></label>
                    <input asp-for="Item.Date" type="date" class="form-control" />
                    <span asp-validation-for="Item.Date" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Item.Type" class="form-label"></label>
                    <select asp-for="Item.Type" asp-items="Html.GetEnumSelectList<NoticeType>()" class="form-select"></select>
                </div>
                <div class="col-md-12">
                    <label asp-for="Item.Title" class="form-label"></label>
                    <input asp-for="Item.Title" class="form-control" />
                    <span asp-validation-for="Item.Title" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="Item.Body" class="form-label"></label>
                    <textarea asp-for="Item.Body" class="form-control" rows="6"></textarea>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save</button>
                <a href="/admin/notices" class="btn btn-link">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
