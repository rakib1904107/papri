@page "/admin/notices"
@model Papri.Pages.Admin.Notices.IndexModel
@{
    ViewData["Title"] = "Notices";
    ViewData["SearchPlaceholder"] = "Search notices...";
    ViewData["NewButtonText"] = "New Notice";
    ViewData["NewButtonHref"] = "/admin/notices/create";
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success py-2"><i class="bi bi-check-circle me-1"></i> @Model.StatusMessage</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <partial name="_SearchBar" />
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 70px;">Id</th>
                        <th style="width: 130px;">Date</th>
                        <th style="width: 90px;">Type</th>
                        <th>Title</th>
                        <th>Description</th>
                        <th style="width: 160px;" class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">No notices yet.</td></tr>
                    }
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Date.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="badge @(item.Type == NoticeType.News ? "bg-info-soft text-info" : "bg-warning-soft text-warning")">@item.Type</span>
                            </td>
                            <td>@item.Title</td>
                            <td class="text-truncate" style="max-width: 320px;" title="@item.Body">
                                @(string.IsNullOrEmpty(item.Body) ? "—" : item.Body)
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" href="/admin/notices/edit/@item.Id"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="/admin/notices?handler=Delete&id=@item.Id" class="d-inline" onsubmit="return confirm('Delete this notice?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="(Papri.Services.IPagedList)Model.Items" />
    </div>
</div>
