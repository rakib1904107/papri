@page "/admin/news"
@model Papri.Pages.Admin.News.IndexModel
@{
    ViewData["Title"] = "News";
    ViewData["SearchPlaceholder"] = "Search news...";
    ViewData["NewButtonText"] = "New Item";
    ViewData["NewButtonHref"] = "/admin/news/create";
    var currentQ = HttpContext.Request.Query["q"].ToString();
    var currentPage = HttpContext.Request.Query["page"].ToString();
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success py-2"><i class="bi bi-check-circle me-1"></i> @Model.StatusMessage</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <partial name="_SearchBar" />
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 60px;">Id</th>
                        <th style="width: 90px;">Image</th>
                        <th style="width: 120px;">Date</th>
                        <th>Title</th>
                        <th>Details</th>
                        <th style="width: 130px;" class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">No news yet.</td></tr>
                    }
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <img src="@item.ImagePath" class="img-thumbnail" style="width:64px;height:48px;object-fit:cover;" />
                                }
                                else { <span class="text-muted small">—</span> }
                            </td>
                            <td>@item.Date.ToString("yyyy-MM-dd")</td>
                            <td>@item.Title</td>
                            <td class="text-truncate" style="max-width: 280px;">@item.Details</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" href="/admin/news/edit/@item.Id"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="/admin/news?handler=Delete&id=@item.Id" class="d-inline" onsubmit="return confirm('Delete this news item?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="(Papri.Services.IPagedList)Model.Items" />
    </div>
</div>
