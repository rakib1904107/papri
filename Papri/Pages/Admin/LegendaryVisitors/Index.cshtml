@page "/admin/legendary-visitors"
@model Papri.Pages.Admin.LegendaryVisitors.IndexModel
@{
    ViewData["Title"] = "Legendary Visitors";
    ViewData["SearchPlaceholder"] = "Search visitors...";
    ViewData["NewButtonText"] = "New Visitor";
    ViewData["NewButtonHref"] = "/admin/legendary-visitors/create";
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success py-2"><i class="bi bi-check-circle me-1"></i> @Model.StatusMessage</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <partial name="_SearchBar" />
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 70px;">Id</th>
                        <th style="min-width: 12rem;">Name</th>
                        <th style="min-width: 10rem;">Designation</th>
                        <th style="min-width: 14rem;">Country / Institution</th>
                        <th style="width: 8rem;">Year</th>
                        <th style="width: 80px;">Order</th>
                        <th style="width: 100px;">Status</th>
                        <th style="width: 160px;" class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No visitors yet.</td></tr>
                    }
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="fw-medium">@item.Name</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Designation) ? "—" : item.Designation)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.CountryInstitution) ? "—" : item.CountryInstitution)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Year) ? "—" : item.Year)</td>
                            <td>@item.DisplayOrder</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success-soft text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" href="/admin/legendary-visitors/edit/@item.Id"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="/admin/legendary-visitors?handler=Delete&id=@item.Id" class="d-inline" onsubmit="return confirm('Delete this visitor?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="(Papri.Services.IPagedList)Model.Items" />
    </div>
</div>
