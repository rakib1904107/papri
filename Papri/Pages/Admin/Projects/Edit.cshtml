@page "/admin/projects/edit/{id:int}"
@model Papri.Pages.Admin.Projects.EditModel
@{
    ViewData["Title"] = "Edit Project";
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Item.Date" class="form-label"></label>
                    <input asp-for="Item.Date" type="date" class="form-control" />
                </div>
                <div class="col-md-8">
                    <label asp-for="Item.Title" class="form-label"></label>
                    <input asp-for="Item.Title" class="form-control" />
                    <span asp-validation-for="Item.Title" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    @if (!string.IsNullOrEmpty(Model.Item.ImagePath))
                    {
                        <div class="mb-2">
                            <img src="@Model.Item.ImagePath" class="img-thumbnail" style="max-height:120px;" />
                        </div>
                    }
                    <label asp-for="ImageFile" class="form-label">Replace image (optional)</label>
                    <input asp-for="ImageFile" type="file" accept="image/*" class="form-control" />
                    <span asp-validation-for="ImageFile" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Item.Details" class="form-label"></label>
                    <textarea asp-for="Item.Details" class="form-control" rows="6"></textarea>
                    <span asp-validation-for="Item.Details" class="text-danger small"></span>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Update</button>
                <a href="/admin/projects" class="btn btn-link">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
