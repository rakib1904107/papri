@page "/admin/videos/create"
@model Papri.Pages.Admin.Videos.CreateModel
@{
    ViewData["Title"] = "New Video";
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
            <div class="mb-3">
                <label asp-for="Item.Title" class="form-label"></label>
                <input asp-for="Item.Title" class="form-control" />
                <span asp-validation-for="Item.Title" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Item.YouTubeId" class="form-label">YouTube video ID or URL</label>
                <input asp-for="Item.YouTubeId" class="form-control" placeholder="dQw4w9WgXcQ" />
                <div class="form-text">You can paste the full URL — only the ID will be stored.</div>
                <span asp-validation-for="Item.YouTubeId" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save</button>
            <a href="/admin/videos" class="btn btn-link">Cancel</a>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
