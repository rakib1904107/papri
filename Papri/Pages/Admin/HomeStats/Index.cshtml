@page "/admin/home-stats"
@model Papri.Pages.Admin.HomeStats.IndexModel
@{
    ViewData["Title"] = "Home Stats";
    ViewData["SearchPlaceholder"] = "Search stats...";
    ViewData["NewButtonText"] = "New Stat";
    ViewData["NewButtonHref"] = "/admin/home-stats/create";
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success py-2"><i class="bi bi-check-circle me-1"></i> @Model.StatusMessage</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <partial name="_SearchBar" />
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 70px;">Id</th>
                        <th style="width: 80px;">Icon</th>
                        <th style="min-width: 14rem;">Label</th>
                        <th style="width: 10rem;">Value</th>
                        <th style="width: 80px;">Order</th>
                        <th style="width: 100px;">Status</th>
                        <th style="width: 160px;" class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No stats yet.</td></tr>
                    }
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.Icon))
                                {
                                    <i class="bi @item.Icon" style="font-size: 1.25rem;"></i>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td class="fw-medium">@item.Label</td>
                            <td class="fw-bold">@item.Value</td>
                            <td>@item.DisplayOrder</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success-soft text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" href="/admin/home-stats/edit/@item.Id"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="/admin/home-stats?handler=Delete&id=@item.Id" class="d-inline" onsubmit="return confirm('Delete this stat?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="(Papri.Services.IPagedList)Model.Items" />
    </div>
</div>
