@page "/admin/jobs"
@model Papri.Pages.Admin.Jobs.IndexModel
@{
    ViewData["Title"] = "Job Opportunities";
    ViewData["SearchPlaceholder"] = "Search jobs...";
    ViewData["NewButtonText"] = "New Job";
    ViewData["NewButtonHref"] = "/admin/jobs/create";
    var currentQ = HttpContext.Request.Query["q"].ToString();
    var currentPage = HttpContext.Request.Query["page"].ToString();
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success py-2"><i class="bi bi-check-circle me-1"></i> @Model.StatusMessage</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <partial name="_SearchBar" />
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 60px;">Id</th>
                        <th>Job title</th>
                        <th style="width: 130px;">Posted</th>
                        <th style="width: 130px;">Deadline</th>
                        <th style="width: 200px;" class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">No job opportunities yet.</td></tr>
                    }
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>
                                <a href="@item.CircularPath" target="_blank" rel="noopener" class="text-decoration-none">
                                    <i class="bi bi-file-earmark-pdf text-danger me-1"></i>@item.JobTitle
                                </a>
                            </td>
                            <td>@item.PostedDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (item.Deadline < DateTime.UtcNow.Date)
                                {
                                    <span class="text-danger">@item.Deadline.ToString("yyyy-MM-dd")</span>
                                }
                                else { @item.Deadline.ToString("yyyy-MM-dd") }
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" href="@item.CircularPath" target="_blank"><i class="bi bi-file-earmark-text"></i></a>
                                <a class="btn btn-sm btn-outline-primary" href="/admin/jobs/edit/@item.Id"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="/admin/jobs?handler=Delete&id=@item.Id" class="d-inline" onsubmit="return confirm('Delete this job?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="(Papri.Services.IPagedList)Model.Items" />
    </div>
</div>
