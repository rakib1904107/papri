@page "/admin/jobs/create"
@model Papri.Pages.Admin.Jobs.CreateModel
@{
    ViewData["Title"] = "New Job Opportunity";
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Item.JobTitle" class="form-label"></label>
                    <input asp-for="Item.JobTitle" class="form-control" />
                    <span asp-validation-for="Item.JobTitle" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Item.PostedDate" class="form-label"></label>
                    <input asp-for="Item.PostedDate" type="date" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Item.Deadline" class="form-label"></label>
                    <input asp-for="Item.Deadline" type="date" class="form-control" />
                    <span asp-validation-for="Item.Deadline" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="CircularFile" class="form-label">Circular (PDF, DOC, DOCX — max 25 MB)</label>
                    <input asp-for="CircularFile" type="file" accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" class="form-control" />
                    <span asp-validation-for="CircularFile" class="text-danger small"></span>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save</button>
                <a href="/admin/jobs" class="btn btn-link">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
