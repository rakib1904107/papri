@page "/media/photo-gallery"
@model Papri.Pages.Media.PhotoGalleryModel
@{
    ViewData["Title"] = "Photo Gallery";
}

<section class="container-fluid gallery-page py-4">
    <div class="text-center mb-4">
        <h1 class="h3 mb-1">Photo Gallery</h1>
        <p class="text-muted mb-0">Moments from our work and community.</p>
    </div>

    @if (!Model.Photos.Any())
    {
        <div class="alert alert-light border text-center">No photos available yet.</div>
    }
    else
    {
        <div class="row gx-3 gy-5">
            @{ var photoIndex = 0; }
            @foreach (var photo in Model.Photos)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <a href="#" class="photo-card d-block"
                       data-bs-toggle="modal"
                       data-bs-target="#photoModal"
                       data-index="@photoIndex"
                       data-img="@photo.ImagePath"
                       data-caption="@(photo.Caption ?? "")">
                        <div class="ratio ratio-4x3 bg-light rounded overflow-hidden">
                            <img src="@photo.ImagePath"
                                 alt="@(photo.Caption ?? "Photo")"
                                 loading="lazy"
                                 class="w-100 h-100" style="object-fit: cover;" />
                        </div>
                        @if (!string.IsNullOrWhiteSpace(photo.Caption))
                        {
                            <div class="small text-muted mt-1 text-truncate">@photo.Caption</div>
                        }
                    </a>
                </div>
                photoIndex++;
            }
        </div>
    }
</section>

<div class="modal fade" id="photoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-dark text-white border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="photoModalCaption"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-0 position-relative">
                <button type="button" id="photoModalPrev" class="photo-nav-btn photo-nav-prev" aria-label="Previous photo">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <img id="photoModalImg" src="" alt="" class="img-fluid" style="max-height: 80vh; object-fit: contain;" />
                <button type="button" id="photoModalNext" class="photo-nav-btn photo-nav-next" aria-label="Next photo">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var modal = document.getElementById('photoModal');
        if (!modal) return;

        var imgEl = modal.querySelector('#photoModalImg');
        var captionEl = modal.querySelector('#photoModalCaption');
        var prevBtn = modal.querySelector('#photoModalPrev');
        var nextBtn = modal.querySelector('#photoModalNext');

        var cards = Array.prototype.slice.call(document.querySelectorAll('.photo-card'));
        var photos = cards.map(function (c) {
            return {
                src: c.getAttribute('data-img') || '',
                caption: c.getAttribute('data-caption') || ''
            };
        });
        var currentIndex = 0;

        function render(i) {
            if (!photos.length) return;
            currentIndex = (i + photos.length) % photos.length;
            var p = photos[currentIndex];
            imgEl.setAttribute('src', p.src);
            captionEl.textContent = p.caption;
        }

        modal.addEventListener('show.bs.modal', function (event) {
            var trigger = event.relatedTarget;
            if (!trigger) return;
            var idx = parseInt(trigger.getAttribute('data-index') || '0', 10);
            render(isNaN(idx) ? 0 : idx);
        });

        modal.addEventListener('hidden.bs.modal', function () {
            imgEl.setAttribute('src', '');
        });

        prevBtn.addEventListener('click', function () { render(currentIndex - 1); });
        nextBtn.addEventListener('click', function () { render(currentIndex + 1); });

        document.addEventListener('keydown', function (e) {
            if (!modal.classList.contains('show')) return;
            if (e.key === 'ArrowLeft') { render(currentIndex - 1); }
            else if (e.key === 'ArrowRight') { render(currentIndex + 1); }
        });
    });
</script>
}
