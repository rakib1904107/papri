@{
    var query = ViewContext.HttpContext.Request.Query["q"].ToString();
    var placeholder = (string?)ViewData["SearchPlaceholder"] ?? "Search...";
    var newButtonText = (string?)ViewData["NewButtonText"];
    var newButtonHref = (string?)ViewData["NewButtonHref"];
    var path = ViewContext.HttpContext.Request.Path;
}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <form method="get" action="@path" class="d-flex flex-grow-1" style="max-width: 360px;" role="search">
        <input type="search" name="q" value="@query" class="form-control form-control-sm me-2" placeholder="@placeholder" />
        <button type="submit" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-search"></i>
        </button>
        @if (!string.IsNullOrEmpty(query))
        {
            <a href="@path" class="btn btn-sm btn-outline-secondary ms-2"><i class="bi bi-x"></i></a>
        }
    </form>
    @if (!string.IsNullOrEmpty(newButtonHref))
    {
        <a href="@newButtonHref" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg me-1"></i>@(newButtonText ?? "New")
        </a>
    }
</div>
