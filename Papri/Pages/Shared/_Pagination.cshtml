@model Papri.Services.IPagedList
@{
    if (Model is null || Model.TotalCount == 0) { return; }

    var path = ViewContext.HttpContext.Request.Path.ToString();
    var queryItems = ViewContext.HttpContext.Request.Query;

    string PageUrl(int p)
    {
        var parts = new List<string>();
        foreach (var kv in queryItems)
        {
            if (kv.Key.Equals("page", StringComparison.OrdinalIgnoreCase)) continue;
            var val = kv.Value.ToString();
            if (string.IsNullOrEmpty(val)) continue;
            parts.Add($"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(val)}");
        }
        parts.Add($"page={p}");
        return path + "?" + string.Join("&", parts);
    }

    var window = 2;
    var start = Math.Max(1, Model.PageIndex - window);
    var end = Math.Min(Model.TotalPages, Model.PageIndex + window);
    var first = (Model.PageIndex - 1) * Model.PageSize + 1;
    var last = Math.Min(Model.TotalCount, Model.PageIndex * Model.PageSize);
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-3">
    <small class="text-muted">
        Showing <strong>@first</strong>–<strong>@last</strong> of <strong>@Model.TotalCount</strong>
    </small>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Pagination">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(!Model.HasPrevious ? "disabled" : "")">
                    <a class="page-link" href="@PageUrl(Model.PageIndex - 1)">&laquo;</a>
                </li>

                @if (start > 1)
                {
                    <li class="page-item"><a class="page-link" href="@PageUrl(1)">1</a></li>
                    @if (start > 2) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                }

                @for (var p = start; p <= end; p++)
                {
                    <li class="page-item @(p == Model.PageIndex ? "active" : "")">
                        <a class="page-link" href="@PageUrl(p)">@p</a>
                    </li>
                }

                @if (end < Model.TotalPages)
                {
                    @if (end < Model.TotalPages - 1) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                    <li class="page-item"><a class="page-link" href="@PageUrl(Model.TotalPages)">@Model.TotalPages</a></li>
                }

                <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                    <a class="page-link" href="@PageUrl(Model.PageIndex + 1)">&raquo;</a>
                </li>
            </ul>
        </nav>
    }
</div>
